@model NyloStreetwearMVC1.Data.Entities.Category

@{
    ViewData["Title"] = "Details";
}

<div class="container mt-4">

    <h1 class="mb-4">@Model.Name</h1>
    <hr />

    <div class="row">
        @foreach (var pc in Model.ProductCategories)
        {
            var product = pc.Product;

            <div class="col-6 col-md-4 col-lg-3 mb-4">
                <div class="card h-100 shadow-sm">

                    <img src="@product.ImageUrl"
                         class="card-img-top photo"
                         alt="@product.Title"
                         style="height:300px; object-fit:cover;" />

                    <div class="card-body text-center">
                        <h6>@product.Title</h6>
                        <p class="text-muted">@product.Price.ToString("C")</p>
                    </div>

                    <div class="card-footer text-center">
                        <a asp-controller="Products"
                           asp-action="Details"
                           asp-route-id="@product.Id"
                           class="btn btn-dark">
                            View Product
                        </a>
                    </div>

                </div>
            </div>
        }
    </div>

</div>